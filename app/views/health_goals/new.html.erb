<div class="container py-5">
  <h1 class="mb-4">New Health Goal</h1>

  <%= form_with model: @health_goal do |f| %>
    <div class="mb-3">
      <%= f.label :name, "Goal", class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :module, "Category", class: "form-label" %>
      <%= f.text_field :module, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :content, "Details", class: "form-label" %>
      <%= f.text_area :content, class: "form-control", rows: 5 %>
    </div>

    <%= f.submit "Create Health Goal", class: "btn btn-primary" %>
  <% end %>
</div>
