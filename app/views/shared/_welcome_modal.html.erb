<div class="welcome-modal-overlay" data-controller="welcome-modal">
  <div class="welcome-modal">
    <button type="button" class="welcome-modal__close" data-action="welcome-modal#dismiss" aria-label="Close">&times;</button>

    <div class="welcome-modal__icon">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z" fill="white"/>
        <circle cx="12" cy="9" r="2.5" fill="#174d36"/>
      </svg>
    </div>

    <h2 class="welcome-modal__title">Welcome to My Healthy Map 🌿</h2>
    <p class="welcome-modal__body">
      Search for your favourite spot in the search bar, or find a new one on the map.
      Save it, define your health goals, and discuss them anytime with your AI coach.
    </p>

    <div class="welcome-modal__actions">
      <button type="button" class="btn btn-primary" data-action="welcome-modal#dismiss">Let's go</button>
    </div>
  </div>
</div>
