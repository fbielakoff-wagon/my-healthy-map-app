<div class="auth-page">
  <div class="auth-card">
    <h2>Log in</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>
        <%= f.input :password,
                    required: false,
                    input_html: { autocomplete: "current-password" } %>
        <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Log in", class: "auth-submit-btn" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

<style>
  .auth-page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 80px 20px;
    min-height: 80vh;
    background-color: #f7f6f2;
  }

  .auth-card {
    width: 100%;
    max-width: 400px;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    padding: 2.5rem;
  }

  .auth-card h2 {
    margin-bottom: 1.5rem;
    font-weight: 700;
    text-align: center;
  }

  .auth-card .form-inputs {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .auth-card label {
    font-weight: 500;
    margin-bottom: 0.35rem;
    display: block;
  }

  .auth-card input[type="text"],
  .auth-card input[type="email"],
  .auth-card input[type="password"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid #d8d8d3;
    border-radius: 8px;
    font-size: 1rem;
  }

  .auth-card input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  .auth-submit-btn {
    width: 100%;
    padding: 0.7rem;
    background-color: #2f5d3a;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .auth-submit-btn:hover {
    background-color: #24462c;
  }

  .auth-links {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.9rem;
  }

  .auth-links a {
    color: #2f5d3a;
    text-decoration: underline;
    display: block;
    margin-top: 0.4rem;
  }
</style>
