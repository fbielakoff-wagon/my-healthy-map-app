<div class="coach-page">
  <div class="coach-page__content">
    <header class="coach-intro">
      <h1 class="coach-intro__title">My Coach</h1>

      <p class="coach-intro__text">
        Get personalised support based on your goals and favourite places.
      </p>

      <% if @active_goal.present? %>
        <%= button_to "💬 Start a conversation",
                      health_goal_chats_path(@active_goal),
                      method: :post,
                      params: {
                        chat: {
                          title: "General coaching"
                        }
                      },
                      class: "coach-cta" %>
      <% else %>
        <%= link_to "Set your first goal",
                    new_health_goal_path,
                    class: "coach-cta" %>
      <% end %>
    </header>

    <section class="coach-section">
      <div class="coach-section__heading">
        <h2>Health goals</h2>

        <%= link_to "+ Add goal",
                    new_health_goal_path,
                    class: "coach-section__link" %>
      </div>

      <% if @health_goals.any? %>
        <div class="coach-goals-grid">
          <% @health_goals.each do |goal| %>
            <div class="coach-goal-card shadow-box">
              <%= link_to edit_health_goal_path(goal), class: "coach-goal-card__edit", "aria-label": "Edit goal" do %>
                ✏️
              <% end %>

              <%= link_to health_goal_path(goal), class: "coach-goal-card__body" do %>
                <% if goal.module.present? %>
                  <span class="coach-goal-card__tag"><%= goal.module %></span>
                <% end %>

                <h3 class="coach-goal-card__name"><%= goal.name %></h3>
                <span class="coach-goal-card__cta">Chat about this goal →</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="coach-section__empty">
          You haven't created any health goals yet.
        </p>
      <% end %>
    </section>

    <section class="coach-section">
      <h2>Recent conversations</h2>

      <% if @recent_chats.any? %>
        <div class="coach-chats-list">
          <% @recent_chats.each do |chat| %>
            <%= link_to chat_path(chat), class: "coach-chat-item" do %>
              <span class="coach-chat-item__icon">💬</span>

              <span class="coach-chat-item__text">
                <strong><%= chat.title.presence || chat.health_goal.name %></strong>

                <% if chat.spot.present? %>
                  <span class="coach-chat-item__meta">📍 <%= chat.spot.name %></span>
                <% end %>
              </span>

              <span class="coach-chat-item__arrow">→</span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="coach-section__empty">No conversations yet.</p>
      <% end %>
    </section>
  </div>
</div>
